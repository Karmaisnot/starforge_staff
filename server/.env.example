# Copy to .env and adjust. Never commit .env.
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Local dev uses SQLite (zero infra). For Postgres, set the schema datasource
# provider to "postgresql" and use a URL like the commented one below.
DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://starforge:starforge@localhost:5433/starforge_edu?schema=public

# Auth
JWT_SECRET=dev-only-change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# CORS — the Vite dev origin
CORS_ORIGIN=http://localhost:5173

# AI grading/level assessment. Leave ANTHROPIC_API_KEY empty to use the
# deterministic/heuristic fallback adapters (the app stays fully functional).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
