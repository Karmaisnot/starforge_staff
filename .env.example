# Keep the polished local demo working without a backend.
VITE_USE_MOCK=true

# To use the supplied Starforge API, switch to false. Keep VITE_API_BASE_URL
# empty for same-origin production hosting; Vite proxies relative /api calls in development.
# VITE_USE_MOCK=false
# VITE_API_PROXY_TARGET=https://starforge.78.111.91.113.nip.io
# VITE_API_BASE_URL=

# Current staff accounts are role-native. Set legacy-login only for an old backend.
VITE_AUTH_ENDPOINT=role-login
